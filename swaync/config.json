{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "left",
  "positionY": "top",
  "timeout": 6,
  "timeout-low": 4,
  "timeout-critical": 0,

  "notification-window-width": 380,
  "control-center-width": 400,

  "control-center-margin-top": 12,
  "control-center-margin-right": 12,
  "control-center-margin-bottom": 12,

  "fit-to-screen": true,
  "layer": "overlay",
  "control-center-layer": "overlay",

  "cssPriority": "user",
  "ignore-gtk-theme": true,

  "widgets": [
    "title",
    "dnd",
    "mpris",
    "volume",
    "backlight",
    "buttons-grid",
    "buttons-grid#system",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Ayush's Arch",
      "clear-all-button": true,
      "button-text": "Clear All"
    },

    "dnd": {
      "label": "Focus Mode"
    },

    "mpris": {
      "image-size": 64,
      "image-radius": 16
    },

    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },

    "backlight": {
      "label": "󰃟",
      "device": "amdgpu_bl2"
    },

    "buttons-grid": {
      "columns": 2,
      "actions": [
        {
          "label": "󰤨  Wi-Fi",
          "command": "nmtui",
          "tooltip": "Wireless Settings"
        },
        {
          "label": "󰂯  Bluetooth",
          "command": "blueman-manager",
          "tooltip": "Bluetooth Devices"
        },
        {
          "label": "󰕾  Sound",
          "command": "pavucontrol",
          "tooltip": "Audio Settings"
        },
        {
          "label": "󰐻  Picker",
          "command": "hyprpicker -a",
          "tooltip": "Color Picker"
        },
        {
  "label": "󰏲  Phone",
  "command": "kdeconnect-app",
  "tooltip": "Connect to phone"
},
        {
  "label": "󰊴  Rog Center",
  "command": "rog-control-center",
  "tooltip": "rog-control-center"
}
      ]
    },

    "buttons-grid#system": {
      "columns": 4,
      "actions": [
        {
          "label": "󰌾",
          "command": "hyprlock",
          "tooltip": "Lock Screen"
        },
        {
          "label": "󰒲",
          "command": "systemctl suspend",
          "tooltip": "Sleep"
        },
        {
          "label": "󰑐",
          "command": "systemctl reboot",
          "tooltip": "Restart"
        },
        {
          "label": "󰐥",
          "command": "systemctl poweroff",
          "tooltip": "Shut Down"
        }
      ]
    }
  }
}